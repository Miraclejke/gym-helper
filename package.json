{
  "name": "gym-helper",
  "version": "0.0.1",
  "description": "GymHelper backend on NestJS",
  "author": "Mihail",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:frontend && npm run build:backend",
    "build:backend": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "build:frontend": "cd frontend && npm ci --include=dev && npm run build",
    "format": "prettier --write \"src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\" \"prisma/seed.js\"",
    "prisma:generate": "npx prisma generate",
    "prisma:validate": "npx prisma validate",
    "prisma:studio": "npx prisma studio",
    "prisma:migrate:dev": "npx prisma migrate dev",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:migrate:render": "npx prisma migrate deploy",
    "prisma:seed": "npm run prisma:generate && npx prisma db seed",
    "start": "npx nest start",
    "start:dev": "npx nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/express-session": "^1.18.2",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express-handlebars": "^9.0.1",
    "express-session": "^1.19.0",
    "graphql": "^16.13.2",
    "graphql-query-complexity": "^1.1.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
